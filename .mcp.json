{
  "mcpServers": {
    "redmine": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "mcp-redmine==2026.01.13.152335",
        "--refresh-package",
        "mcp-redmine",
        "mcp-redmine"
      ],
      "env": {
        "REDMINE_URL": "${REDMINE_URL}",
        "REDMINE_API_KEY": "${REDMINE_API_KEY}",
        "REDMINE_ALLOWED_DIRECTORIES": "/tmp/redmine-uploads"
      }
    }
  }
}
