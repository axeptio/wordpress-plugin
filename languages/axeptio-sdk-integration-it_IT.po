#: templates/admin/main/fields/google-consent-mode.php:72
msgid "Ad Storage"
msgstr "Ad Storage"

#: templates/admin/main/fields/google-consent-mode.php:73
msgid ""
"Permit Google to save advertising information on visitors' devices for "
"better ad relevance."
msgstr ""
"Consentire a Google di salvare informazioni pubblicitarie sui dispositivi "
